# ─── MailProbe Environment Variables ──────────────────────────────────────
# All features are FREE — no paid tier.

# RATE LIMITING
RATE_LIMIT_FREE=100        # Single verify requests per day per IP
FREE_BULK_LIMIT=500        # Max emails per bulk job (free)
BULK_CONCURRENCY=10        # Parallel workers for bulk processing

# SMTP WORKER (Railway) — required for catch-all + invalid detection
# Without this, accuracy is ~72%. With it, accuracy is ~95%+
# See smtp-worker/DEPLOY.md for setup
SMTP_WORKER_URL=           # https://your-worker.up.railway.app
SMTP_WORKER_SECRET=        # Must match SMTP_SECRET on Railway

# OPTIONAL: Vercel KV — persistent rate limiting across serverless instances
KV_REST_API_URL=
KV_REST_API_TOKEN=

# CORS
ALLOWED_ORIGINS=*

NODE_ENV=production

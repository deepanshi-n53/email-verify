# ─── MailProbe Environment Variables ──────────────────────────────────────────
# Copy to .env.local for local dev. Set in Vercel dashboard for production.

# FRONTEND — leave empty on Vercel (uses relative /api/* calls)
VITE_API_URL=

# RATE LIMITING
RATE_LIMIT_FREE=100
FREE_BULK_LIMIT=50
PRO_BULK_LIMIT=500
BULK_CONCURRENCY=10

# OPTIONAL: Railway SMTP worker for real RCPT probing (port 25)
SMTP_WORKER_URL=
SMTP_WORKER_SECRET=

# OPTIONAL: Vercel KV for persistent rate limiting
KV_REST_API_URL=
KV_REST_API_TOKEN=

# OPTIONAL: Vercel Postgres for result storage
POSTGRES_URL=

# CORS (comma-separated origins or *)
ALLOWED_ORIGINS=*

NODE_ENV=production

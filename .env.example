# ─── MailProbe Environment Variables ──────────────────────────────────────

# No login or API key required. All features are free.

# FRONTEND — leave empty on Vercel (uses relative /api/* calls)
VITE_API_URL=

# RATE LIMITING
RATE_LIMIT_FREE=100        # Single verify: requests per day per IP
FREE_BULK_LIMIT=500        # Bulk verify: max emails per job
BULK_CONCURRENCY=10        # Parallel workers for bulk processing

# OPTIONAL: Vercel KV (makes rate limits persist across serverless instances)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# OPTIONAL: SMTP Worker on Railway (improves accuracy for non-major domains)
# See api/_lib/SMTP_WORKER.md for setup instructions
SMTP_WORKER_URL=
SMTP_WORKER_SECRET=

# CORS
ALLOWED_ORIGINS=*

NODE_ENV=production
